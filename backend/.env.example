# Backend environment example
# Do NOT commit real secrets. Copy this to .env when running locally.

# Comma-separated allowed origins for CORS (cloudfront/pages domain). Use '*' only for local testing.
ALLOW_ORIGINS=https://your-frontend.pages.dev

# Port (Render provides $PORT at runtime)
PORT=8000
# Backend example env
PORT=8000
ALLOW_ORIGINS='*' # For production set to your frontend origin
